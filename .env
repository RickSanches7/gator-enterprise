# ═══════════════════════════════════════════════════════════
# GATOR PRO ENTERPRISE — Environment Configuration
# ═══════════════════════════════════════════════════════════
# ВАЖНО: Измени все пароли перед деплоем в production!
# Скопируй в .env: cp .env.example .env

# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=gator_enterprise
POSTGRES_USER=gator
POSTGRES_PASSWORD=GatorSecureDB1232024

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=GatorRedis1232024

# ─── Application ────────────────────────────────────────────
# Сгенерируй: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

ENVIRONMENT=production
# ENVIRONMENT=development   # включает hot-reload и debug

# ─── Telegram Bot (для Critical алертов) ────────────────────
# Получи токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=
# Получи chat_id: отправь сообщение боту и открой:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ─── NVD CVE API (необязательно — без ключа лимит 5 req/30s) 
# Получи бесплатно: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ─── Flower (Celery monitoring) ─────────────────────────────
FLOWER_USER=gator
FLOWER_PASSWORD=gator-flower-2024

# ─── Shodan (необязательно) ──────────────────────────────────
SHODAN_API_KEY=

# ─── Ports ──────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=8080
